{
  "name": "localelint",
  "version": "0.0.1",
  "description": "Localization CI for iOS apps. XLIFF and Xcode String Catalog validation.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "localelint": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "build:action": "ncc build action/main.ts -o action/dist --target es2022",
    "build:all": "npm run build && npm run build:action",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fast-xml-parser": "^4.5.0"
  },
  "devDependencies": {
    "@actions/core": "^1.11.0",
    "@actions/github": "^6.0.0",
    "@types/node": "^22.0.0",
    "@vercel/ncc": "^0.38.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED",
  "private": true
}
